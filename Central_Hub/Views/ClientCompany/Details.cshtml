@using Central_Hub.Models
@using Central_Hub.Models.ViewModels
@model CompanyDetailsViewModel
@{
    ViewData["Title"] = $"{Model.Company.CompanyName} — Declarify Central Hub";
    Layout = null;

    var adminName = User.Identity?.Name ?? "Admin";
    var initials = string.Concat(adminName.Split(' ').Take(2).Select(w => w.FirstOrDefault())).ToUpper();
    if (string.IsNullOrEmpty(initials)) initials = "CA";

    var coInitials = string.Concat((Model.Company.CompanyName ?? "??").Split(' ').Take(2).Select(w => w.FirstOrDefault())).ToUpper();

    var statusCls = Model.Company.LicenseStatus switch
    {
        LicenseStatus.Active => "active",
        LicenseStatus.ExpiringSoon => "expiring",
        LicenseStatus.Expired => "expired",
        LicenseStatus.Trial => "trial",
        _ => "pending"
    };

    var creditPct = Model.TotalCreditsPurchased > 0
        ? (int)Math.Round((double)Model.TotalCreditsUsed / Model.TotalCreditsPurchased * 100) : 0;

    var maskedKey = (Model.Company.LicenseKey?.Length ?? 0) > 8
        ? Model.Company.LicenseKey![..4] + "••••••••" + Model.Company.LicenseKey![^4..]
        : "••••••••";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="~/css/hubcss.css" rel="stylesheet">
    <link href="~/css/clientdetailcss.css" rel="stylesheet" />
</head>
<body>

    <!-- ── Navbar ──────────────────────────────────────────────── -->
    <nav class="hub-nav">
        <div class="hub-nav-inner">
            <a href="@Url.Action("Index", "Home")" class="hub-brand">
                <img src="~/images/declarify logo.png" alt="Declarify" class="hub-brand-img" />
                <div><div class="hub-brand-text">Declar<span>ify</span></div><div class="hub-brand-sub">Central Hub</div></div>
            </a>
            <span class="hub-env-badge prod" style="margin-left:8px">● Production</span>
            <div class="hub-nav-links" style="margin-left:20px">
                <a href="@Url.Action("Index", "Home")" class="hub-nav-link">Dashboard</a>
                <a href="@Url.Action("Index", "ClientCompany")" class="hub-nav-link active">Clients</a>
                <a href="@Url.Action("ManageDemoRequest", "DemoRequest")" class="hub-nav-link">Demos</a>
                <a href="@Url.Action("RequestedCredits", "Home")" class="hub-nav-link">Credits</a>
            </div>
            <div class="hub-nav-right">
                <div class="hub-nav-user">
                    <div class="hub-nav-av">@initials</div>
                    <div><div class="hub-nav-name">@adminName</div><div class="hub-nav-role">Central Admin</div></div>
                </div>
            </div>
        </div>
    </nav>

    <!-- ── Hero ─────────────────────────────────────────────────── -->
    <div class="hub-hero" style="padding-bottom:36px">
        <div class="hub-hero-inner">
            <div>
                <div class="hub-hero-eyebrow">
                    <a href="@Url.Action("Index", "ClientCompany")" style="color:rgba(255,255,255,.5);text-decoration:none;font-size:.6875rem;font-weight:700">← Client Companies</a>
                </div>

                <div style="display:flex;align-items:center;gap:16px;margin:10px 0 10px">
                    <div style="width:52px;height:52px;border-radius:14px;background:linear-gradient(135deg,rgba(255,255,255,.15),rgba(0,194,203,.3));border:1px solid rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-family:var(--font-d);font-size:1.125rem;font-weight:900;color:#fff;flex-shrink:0">@coInitials</div>
                    <div>
                        <h1 class="hub-hero-title" style="margin-bottom:4px">@Model.Company.CompanyName</h1>
                        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
                            <span class="hub-badge @statusCls"><span class="hub-dot"></span>@Model.Company.LicenseStatus</span>
                            <span style="font-size:.75rem;color:rgba(255,255,255,.45);font-weight:500">@Model.Company.CompanyType</span>
                            <span style="font-size:.75rem;color:rgba(255,255,255,.45);font-weight:500">📍 @Model.Company.Province</span>
                        </div>
                    </div>
                </div>

                <div class="hub-hero-desc" style="margin-bottom:0">
                    Member since @Model.Company.CreatedDate.ToString("dd MMMM yyyy") · License expires @Model.Company.LicenseExpiryDate.ToString("dd MMM yyyy")
                    @if (Model.Company.IsExpiringSoon)
                    {
                        <span style="color:#FCD34D;font-weight:700"> · ⚠ @Model.Company.DaysUntilExpiry days left</span>
                    }
                    else if (Model.Company.IsExpired)
                    {
                        <span style="color:#FCA5A5;font-weight:700"> · ✕ Expired</span>
                    }
                </div>
            </div>

            <div style="display:flex;flex-direction:column;gap:10px;align-items:flex-end">
                <div class="hub-hero-stat" style="text-align:right">
                    <div class="hub-hero-stat-val">@Model.AvailableCredits.ToString("N0")<span> cr</span></div>
                    <div class="hub-hero-stat-lbl">Credits Available</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── KPI Strip ─────────────────────────────────────────────── -->
    <div class="hub-kpi-strip">
        <div class="hub-kpi-inner" style="grid-template-columns:repeat(4,1fr);min-width:400px">
            <div class="hub-kpi cyan">
                <div class="hub-kpi-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15" /></svg></div>
                <div><div class="hub-kpi-val">@Model.AvailableCredits.ToString("N0")</div><div class="hub-kpi-lbl">Available</div></div>
                <div class="hub-kpi-accent"></div>
            </div>
            <div class="hub-kpi green">
                <div class="hub-kpi-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75" /></svg></div>
                <div><div class="hub-kpi-val">@Model.TotalCreditsPurchased.ToString("N0")</div><div class="hub-kpi-lbl">Purchased</div></div>
                <div class="hub-kpi-accent"></div>
            </div>
            <div class="hub-kpi amber">
                <div class="hub-kpi-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15" /></svg></div>
                <div><div class="hub-kpi-val">@Model.TotalCreditsUsed.ToString("N0")</div><div class="hub-kpi-lbl">Used</div></div>
                <div class="hub-kpi-accent"></div>
            </div>
            <div class="hub-kpi navy">
                <div class="hub-kpi-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584" /></svg></div>
                <div><div class="hub-kpi-val">@(Model.Company.EstimatedEmployeeCount?.ToString("N0") ?? "—")</div><div class="hub-kpi-lbl">Employees</div></div>
                <div class="hub-kpi-accent"></div>
            </div>
        </div>
    </div>

    <!-- ── Main ──────────────────────────────────────────────────── -->
    <div class="hub-main">

        @if (TempData["Success"] != null)
        {
            <div class="hub-alert success" style="margin-bottom:16px">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="hub-alert error" style="margin-bottom:16px">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                @TempData["Error"]
            </div>
        }

        <div class="hub-g2" style="align-items:start">

            <!-- ── LEFT: Info panels ────────────────────────────── -->
            <div style="display:flex;flex-direction:column;gap:18px">

                <!-- Company Details -->
                <div class="hub-card hub-anim">
                    <div class="hub-card-head">
                        <div class="hub-card-icon navy">🏢</div>
                        <div><div class="hub-card-title">Company Details</div></div>
                    </div>
                    <div class="hub-card-body">
                        <div class="det-grid">
                            <div class="det-item">
                                <div class="det-label">Registration Number</div>
                                <div class="det-value">@(Model.Company.RegistrationNumber ?? "—")</div>
                            </div>
                            <div class="det-item">
                                <div class="det-label">Email Domain</div>
                                <div class="det-value"><code style="font-size:.8125rem;background:var(--border);padding:2px 6px;border-radius:4px">@@@(Model.Company.EmailDomain ?? "—")</code></div>
                            </div>
                            <div class="det-item">
                                <div class="det-label">Province</div>
                                <div class="det-value">📍 @(Model.Company.Province ?? "—")</div>
                            </div>
                            <div class="det-item">
                                <div class="det-label">City</div>
                                <div class="det-value">@(Model.Company.City ?? "Not specified")</div>
                            </div>
                            <div class="det-item">
                                <div class="det-label">Contact Number</div>
                                <div class="det-value">@(Model.Company.ContactNumber ?? "Not specified")</div>
                            </div>
                            <div class="det-item">
                                <div class="det-label">Member Since</div>
                                <div class="det-value">@Model.Company.CreatedDate.ToString("dd MMM yyyy")</div>
                            </div>
                        </div>

                        <!-- License Key -->
                        <div style="margin-top:14px;padding-top:14px;border-top:1px solid var(--border)">
                            <div class="det-label" style="margin-bottom:8px">License Key</div>
                            <div id="keyPill" class="key-pill" onclick="toggleKey()" title="Click to reveal">
                                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" /></svg>
                                <span id="keyMasked">@maskedKey</span>
                                <span id="keyFull" class="key-show">@Model.Company.LicenseKey</span>
                                <svg id="keyEye" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="margin-left:auto;width:13px;height:13px"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                            </div>
                        </div>

                        <!-- Credit bar -->
                        <div class="credit-bar-wrap" style="margin-top:14px;padding-top:14px;border-top:1px solid var(--border)">
                            <div class="credit-bar-labels">
                                <span>Credit Utilisation</span>
                                <span>@creditPct% used</span>
                            </div>
                            <div class="credit-bar">
                                <div class="credit-fill" id="creditFill" style="width:0%"></div>
                            </div>
                            <div style="display:flex;gap:14px;margin-top:8px;font-size:.625rem;font-weight:600;color:var(--text-muted)">
                                <span style="color:var(--cyan-deep)">● @Model.AvailableCredits.ToString("N0") available</span>
                                <span>● @Model.TotalCreditsUsed.ToString("N0") used</span>
                                <span>● @Model.TotalCreditsPurchased.ToString("N0") purchased</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Administrator -->
                @if (Model.Company.Administrator != null)
                {
                    <div class="hub-card hub-anim">
                        <div class="hub-card-head">
                            <div class="hub-card-icon cyan">👤</div>
                            <div><div class="hub-card-title">Primary Administrator</div></div>
                            <div class="hub-card-action">
                                <a href="mailto:@Model.Company.Administrator.Email" class="hub-btn hub-btn-ghost hub-btn-xs">✉ Email</a>
                            </div>
                        </div>
                        <div class="hub-card-body">
                            <div style="display:flex;align-items:center;gap:14px;margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid var(--border)">
                                <div style="width:46px;height:46px;border-radius:50%;background:linear-gradient(135deg,var(--navy),var(--cyan));color:#fff;font-size:.9375rem;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                    @string.Concat((Model.Company.Administrator.FullName).Split(' ').Take(2).Select(w => w.FirstOrDefault())).ToUpper()
                                </div>
                                <div>
                                    <div style="font-family:var(--font-d);font-size:1rem;font-weight:800;color:var(--navy)">@Model.Company.Administrator.FullName</div>
                                    <div style="font-size:.75rem;color:var(--text-muted);margin-top:2px">@(Model.Company.Administrator.JobTitle ?? "Administrator")</div>
                                </div>
                            </div>
                            <div class="det-grid">
                                <div class="det-item">
                                    <div class="det-label">Email</div>
                                    <div class="det-value"><a href="mailto:@Model.Company.Administrator.Email">@Model.Company.Administrator.Email</a></div>
                                </div>
                                <div class="det-item">
                                    <div class="det-label">Phone</div>
                                    <div class="det-value"><a href="tel:@Model.Company.Administrator.PhoneNumber" style="color:var(--cyan-deep);text-decoration:none">@Model.Company.Administrator.PhoneNumber</a></div>
                                </div>
                                <div class="det-item">
                                    <div class="det-label">Department</div>
                                    <div class="det-value">@(Model.Company.Administrator.Department ?? "Not specified")</div>
                                </div>
                                <div class="det-item">
                                    <div class="det-label">Notifications</div>
                                    <div class="det-value">@(Model.Company.Administrator.ReceiveNotifications ? "✓ Enabled" : "Disabled")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Transaction History -->
                @if (Model.Company.CreditTransactions?.Any() == true)
                {
                    <div class="hub-card hub-anim">
                        <div class="hub-card-head">
                            <div class="hub-card-icon green">💳</div>
                            <div><div class="hub-card-title">Credit Transactions</div><div class="hub-card-sub">Last @Math.Min(10, Model.Company.CreditTransactions.Count()) transactions</div></div>
                        </div>
                        <div class="tx-table-wrap">
                            <table class="tx-table">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Type</th>
                                        <th>Credits</th>
                                        <th>Amount</th>
                                        <th>Reference</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in Model.Company.CreditTransactions.OrderByDescending(x => x.TransactionDate).Take(10))
                                    {
                                        <tr>
                                            <td style="white-space:nowrap;font-weight:500">@t.TransactionDate.ToString("dd MMM yyyy")</td>
                                            <td>
                                                @{
                                                    var tc = t.TransactionType == CreditTransactionType.Purchase ? "approved"
                                                    : t.TransactionType == CreditTransactionType.Spend ? "rejected" : "pending";
                                                }
                                                <span class="hub-badge @tc"><span class="hub-dot"></span>@t.TransactionType</span>
                                            </td>
                                            <td style="font-family:var(--font-d);font-size:.875rem;font-weight:800;color:@(t.TransactionType == CreditTransactionType.Spend ? "var(--danger)" : "var(--cyan-deep)")">
                                                @(t.TransactionType == CreditTransactionType.Spend ? "-" : "+")@t.CreditsAmount.ToString("N0")
                                            </td>
                                            <td style="font-weight:600;white-space:nowrap">@(t.AmountPaid.HasValue ? "R " + t.AmountPaid.Value.ToString("N2") : "—")</td>
                                            <td><code class="ref">@t.ReferenceNumber</code></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <!-- License Renewal History -->
                @if (Model.Company.LicenseRenewals?.Any() == true)
                {
                    <div class="hub-card hub-anim">
                        <div class="hub-card-head">
                            <div class="hub-card-icon amber">🔄</div>
                            <div><div class="hub-card-title">License Renewal History</div></div>
                        </div>
                        <div class="tx-table-wrap">
                            <table class="tx-table">
                                <thead>
                                    <tr><th>Renewal Date</th><th>Previous Expiry</th><th>New Expiry</th><th>Amount</th><th>Method</th><th>By</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in Model.Company.LicenseRenewals!.OrderByDescending(x => x.RenewalDate))
                                    {
                                        <tr>
                                            <td style="white-space:nowrap;font-weight:500">@r.RenewalDate.ToString("dd MMM yyyy")</td>
                                            <td style="white-space:nowrap;color:var(--text-muted)">@r.PreviousExpiryDate.ToString("dd MMM yyyy")</td>
                                            <td style="white-space:nowrap;font-weight:700;color:var(--success)">@r.NewExpiryDate.ToString("dd MMM yyyy")</td>
                                            <td style="font-weight:700;white-space:nowrap">R @r.AmountPaid.ToString("N2")</td>
                                            <td style="color:var(--text-muted);font-size:.75rem">@(r.PaymentMethod ?? "—")</td>
                                            <td style="color:var(--text-muted);font-size:.75rem">@r.ProcessedBy</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>

            <!-- ── RIGHT: Action panels ─────────────────────────── -->
            <div style="display:flex;flex-direction:column;gap:18px;position:sticky;top:76px">

                <!-- Add Credits -->
                <div class="action-panel hub-anim">
                    <div class="action-panel-head">
                        <div class="action-panel-icon">💳</div>
                        <div class="action-panel-title">Add Credits</div>
                        <div class="action-panel-desc">Allocate a new credit batch for @Model.Company.CompanyName. An invoice PDF is required.</div>
                    </div>
                    <div class="action-panel-body">
                        <form asp-action="AddCredit" asp-controller="ClientCompany" method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="companyId" value="@Model.Company.CompanyId" />
                            <input type="hidden" name="purchaseReference" value="@Model.NextCreditPurchaseReference" />

                            <div class="af-field">
                                <label class="af-label">Invoice Number</label>
                                <input type="text" class="af-input" value="@Model.NextCreditPurchaseReference" disabled />
                            </div>
                            <div class="af-row">
                                <div class="af-field">
                                    <label class="af-label">Credit Amount</label>
                                    <input type="number" class="af-input" name="creditAmount" min="1" placeholder="e.g. 500" required />
                                </div>
                                <div class="af-field">
                                    <label class="af-label">Amount Paid (R)</label>
                                    <input type="number" class="af-input" name="amountPaid" step="0.01" min="0" placeholder="e.g. 5000.00" required />
                                </div>
                            </div>
                            <div class="af-field">
                                <label class="af-label">Payment Reference</label>
                                <input type="text" class="af-input" value="@Model.Company.PaymentReference" readonly />
                                <input type="hidden" name="paymentReference" value="@Model.Company.PaymentReference" />
                            </div>
                            <div class="af-field">
                                <label class="af-label">Notes</label>
                                <textarea class="af-input" name="notes" rows="2" placeholder="Optional notes…" style="resize:vertical"></textarea>
                            </div>
                            <div class="af-field">
                                <label class="af-label">Invoice PDF <span style="color:rgba(255,255,255,.35)">(required)</span></label>
                                <input type="file" class="af-input" name="attachment" accept="application/pdf" required style="padding:6px 10px;cursor:pointer" />
                                <div class="af-hint">Credit will not be allocated without an invoice attachment.</div>
                            </div>
                            <button type="submit" class="af-submit">
                                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                                Add Credits
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Renew License -->
                <div class="action-panel hub-anim">
                    <div class="action-panel-head">
                        <div class="action-panel-icon">🔄</div>
                        <div class="action-panel-title">Renew License</div>
                        <div class="action-panel-desc">
                            Current expiry: <strong style="color:#fff">@Model.Company.LicenseExpiryDate.ToString("dd MMM yyyy")</strong><br>
                            New expiry: <strong style="color:var(--cyan)">@Model.Company.LicenseExpiryDate.AddYears(1).ToString("dd MMM yyyy")</strong>
                        </div>
                    </div>
                    <div class="action-panel-body">
                        @{
                            var licRef = $"LIC-{DateTime.UtcNow:yyyyMMdd}-{Model.Company.CompanyId}-{Guid.NewGuid().ToString("N")[..4].ToUpperInvariant()}";
                        }
                        <form asp-action="RenewLicense" method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="companyId" value="@Model.Company.CompanyId" />
                            <input type="hidden" name="invoiceNumber" value="@licRef" />

                            <div class="af-field">
                                <label class="af-label">License Invoice Number</label>
                                <input type="text" class="af-input" value="@licRef" disabled />
                            </div>
                            <div class="af-row">
                                <div class="af-field">
                                    <label class="af-label">Amount Paid (R)</label>
                                    <input type="number" class="af-input" name="amountPaid" step="0.01" min="0" placeholder="e.g. 12000.00" required />
                                </div>
                                <div class="af-field">
                                    <label class="af-label">Payment Method</label>
                                    <select class="af-select" name="paymentMethod" required>
                                        <option value="">Select method…</option>
                                        <option value="EFT">EFT</option>
                                        <option value="Bank Deposit">Bank Deposit</option>
                                        <option value="Card">Card</option>
                                        <option value="Cash">Cash</option>
                                        <option value="Other">Other</option>
                                    </select>
                                </div>
                            </div>
                            <div class="af-field">
                                <label class="af-label">Payment Reference</label>
                                <input type="text" class="af-input" value="@Model.Company.PaymentReference" readonly />
                                <input type="hidden" name="paymentReference" value="@Model.Company.PaymentReference" />
                            </div>
                            <div class="af-field">
                                <label class="af-label">Notes <span style="color:rgba(255,255,255,.35)">(optional)</span></label>
                                <textarea class="af-input" name="notes" rows="2" placeholder="Additional information…" style="resize:vertical"></textarea>
                            </div>
                            <div class="af-field">
                                <label class="af-label">Invoice PDF <span style="color:rgba(255,255,255,.35)">(required)</span></label>
                                <input type="file" class="af-input" name="attachment" accept="application/pdf" required style="padding:6px 10px;cursor:pointer" />
                                <div class="af-hint">License renewal will not be processed without an invoice attachment.</div>
                            </div>
                            <button type="submit" class="af-submit" style="background:linear-gradient(135deg,#081B38,#0D2B5E);box-shadow:0 4px 16px rgba(8,27,56,.4)">
                                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" /></svg>
                                Renew License
                            </button>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script>
        // License key reveal
        var shown = false;
        function toggleKey() {
          shown = !shown;
          document.getElementById('keyMasked').style.display = shown ? 'none' : '';
          document.getElementById('keyFull').style.display   = shown ? '' : 'none';
        }

        // Animate credit bar on load
        window.addEventListener('load', function(){
          var fill = document.getElementById('creditFill');
          if (fill) {
            requestAnimationFrame(function(){
              requestAnimationFrame(function(){
                fill.style.transition = 'width 1s cubic-bezier(.25,.46,.45,.94)';
                fill.style.width = '@creditPct%';
              });
            });
          }
        });

        // Auto-dismiss alerts
        setTimeout(function(){
          document.querySelectorAll('.hub-alert').forEach(function(a){
            a.style.transition='opacity .3s';a.style.opacity='0';
            setTimeout(function(){a.remove()},300);
          });
        },5000);
    </script>
</body>
</html>
