@model IEnumerable<Central_Hub.Models.ClientCompany>
@using Central_Hub.Models
@{
    Layout = null;
    ViewData["Title"] = "Clients — Declarify Central Hub";
    var searchTerm     = ViewBag.SearchTerm as string ?? "";
    var selectedStatus = ViewBag.SelectedStatus as string ?? "all";
    var adminName      = User.Identity?.Name ?? "Admin";
    var initials       = string.Concat(adminName.Split(' ').Take(2).Select(w => w.FirstOrDefault())).ToUpper();
    if (string.IsNullOrEmpty(initials)) initials = "CA";
    var companies = Model.ToList();
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>@ViewData["Title"]</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="~/css/hubcss.css" rel="stylesheet">
</head>
<body>

<!-- ── Navbar ──────────────────────────────────────────────── -->
<nav class="hub-nav">
  <div class="hub-nav-inner">
    <a href="@Url.Action("Index","Home")" class="hub-brand">
      <img src="~/images/declarify logo.png" alt="Declarify" class="hub-brand-img" />
      <div><div class="hub-brand-text">Declar<span>ify</span></div><div class="hub-brand-sub">Central Hub</div></div>
    </a>
    <span class="hub-env-badge prod">● Production</span>
    <div class="hub-nav-links" style="margin-left:24px">
      <a href="@Url.Action("Index","Home")" class="hub-nav-link">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75"/></svg>
        Dashboard
      </a>
      <a href="@Url.Action("Index","ClientCompany")" class="hub-nav-link active">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18"/></svg>
        Clients
      </a>
      <a href="@Url.Action("ManageDemoRequest","DemoRequest")" class="hub-nav-link">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25"/></svg>
        Demos
      </a>
      <a href="@Url.Action("RequestedCredits","Home")" class="hub-nav-link">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15"/></svg>
        Credits
      </a>
    </div>
    <div class="hub-nav-right">
      <div class="hub-nav-user">
        <div class="hub-nav-av">@initials</div>
        <div><div class="hub-nav-name">@adminName</div><div class="hub-nav-role">Central Admin</div></div>
      </div>
    </div>
  </div>
</nav>

<!-- ── Hero ────────────────────────────────────────────────── -->
<div class="hub-hero">
  <div class="hub-hero-inner">
    <div>
      <div class="hub-hero-eyebrow">🏢 Client Management</div>
      <h1 class="hub-hero-title">Client <span>Companies</span></h1>
      <p class="hub-hero-desc">Manage licenses, credits, and compliance settings for all Declarify clients.</p>
      <div class="hub-hero-actions">
        <a href="@Url.Action("Create","ClientCompany")" class="hub-btn hub-btn-cyan">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="width:14px;height:14px"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
          New Client
        </a>
        <a href="@Url.Action("Index","Home")" class="hub-btn hub-btn-ghost" style="color:#fff;border-color:rgba(255,255,255,.25)">← Dashboard</a>
      </div>
    </div>
    <div class="hub-hero-stat">
      <div class="hub-hero-stat-val">@companies.Count(c => c.LicenseStatus == LicenseStatus.Active)<span>/</span>@companies.Count</div>
      <div class="hub-hero-stat-lbl">Active / Total</div>
    </div>
  </div>
</div>

<!-- ── KPI strip ────────────────────────────────────────────── -->
<div class="hub-kpi-strip">
  <div class="hub-kpi-inner">
    <div class="hub-kpi navy"><div class="hub-kpi-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15"/></svg></div><div><div class="hub-kpi-val">@companies.Count</div><div class="hub-kpi-lbl">Total</div></div><div class="hub-kpi-accent"></div></div>
    <div class="hub-kpi green"><div class="hub-kpi-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div><div><div class="hub-kpi-val">@companies.Count(c => c.LicenseStatus == LicenseStatus.Active)</div><div class="hub-kpi-lbl">Active</div></div><div class="hub-kpi-accent"></div></div>
    <div class="hub-kpi amber"><div class="hub-kpi-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div><div><div class="hub-kpi-val">@companies.Count(c => c.LicenseStatus == LicenseStatus.Trial)</div><div class="hub-kpi-lbl">Trial</div></div><div class="hub-kpi-accent"></div></div>
    <div class="hub-kpi red"><div class="hub-kpi-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div><div><div class="hub-kpi-val">@companies.Count(c => c.LicenseStatus == LicenseStatus.Expired)</div><div class="hub-kpi-lbl">Expired</div></div><div class="hub-kpi-accent"></div></div>
    <div class="hub-kpi cyan"><div class="hub-kpi-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71"/></svg></div><div><div class="hub-kpi-val">@companies.Count(c => c.IsExpiringSoon)</div><div class="hub-kpi-lbl">Expiring Soon</div></div><div class="hub-kpi-accent"></div></div>
  </div>
</div>

<!-- ── Main ─────────────────────────────────────────────────── -->
<div class="hub-main">

  @if (TempData["Success"] != null) {
    <div class="hub-alert success"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>@TempData["Success"]</div>
  }
  @if (TempData["Error"] != null) {
    <div class="hub-alert error"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>@TempData["Error"]</div>
  }

  <div class="hub-card hub-anim">
    <!-- Search & filter toolbar -->
    <div class="hub-card-head" style="padding:14px 18px;flex-wrap:wrap;gap:10px">
      <div style="position:relative;flex:1;min-width:200px">
        <svg style="position:absolute;left:11px;top:50%;transform:translateY(-50%);width:15px;height:15px;color:#94A3B8;pointer-events:none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input type="text" id="searchInput" class="hub-input" value="@searchTerm"
               style="padding-left:34px;border-radius:50px;font-size:.8125rem"
               placeholder="Search by name, domain, or registration…" oninput="filterTable()" />
      </div>
                <select id="statusFilter" class="hub-select"
                        style="min-width:150px;border-radius:50px;font-size:.8125rem;width:auto"
                        onchange="filterTable()">

                    <option value="all" selected="@(selectedStatus == "all")">All Statuses</option>
                    <option value="Active" selected="@(selectedStatus == "Active")">Active</option>
                    <option value="Trial" selected="@(selectedStatus == "Trial")">Trial</option>
                    <option value="Expired" selected="@(selectedStatus == "Expired")">Expired</option>
                    <option value="ExpiringSoon" selected="@(selectedStatus == "ExpiringSoon")">Expiring Soon</option>

                </select>
      <span id="countLabel" style="font-size:.75rem;font-weight:600;color:var(--text-muted);white-space:nowrap">
        @companies.Count client@(companies.Count!=1?"s":"")
      </span>
    </div>

    <!-- Table -->
    @if (!companies.Any()) {
      <div class="hub-empty">
        <div class="hub-empty-icon">🏢</div>
        <div class="hub-empty-title">No clients yet</div>
        <div class="hub-empty-desc">Add your first client to get started.</div>
        <a href="@Url.Action("Create","ClientCompany")" class="hub-btn hub-btn-primary" style="margin-top:8px">+ New Client</a>
      </div>
    } else {
      <div class="hub-table-wrap">
        <table class="hub-table" id="clientTable">
          <thead>
            <tr>
              <th>Company</th>
              <th>Type</th>
              <th>License Key</th>
              <th>Status</th>
              <th>Expires</th>
              <th>Security</th>
              <th style="text-align:right">Actions</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var c in companies) {
              var statusCls = c.LicenseStatus == LicenseStatus.Active      ? "active"
                            : c.LicenseStatus == LicenseStatus.Trial        ? "trial"
                            : c.LicenseStatus == LicenseStatus.Expired      ? "expired"
                            : c.LicenseStatus == LicenseStatus.ExpiringSoon ? "expiring"
                            : "pending";
              var maskedKey = c.LicenseKey?.Length > 8
                            ? c.LicenseKey[..4] + "****" + c.LicenseKey[^4..]
                            : "••••••••";
              <tr data-name="@c.CompanyName?.ToLower()"
                  data-status="@c.LicenseStatus">
                <td>
                  <div class="hub-co-cell">
                    <div class="hub-co-av">@string.Concat((c.CompanyName??"??").Split(' ').Take(2).Select(w=>w.FirstOrDefault())).ToUpper()</div>
                    <div>
                      <div class="hub-co-name">@c.CompanyName</div>
                      <div class="hub-co-type">@c.EmailDomain</div>
                    </div>
                  </div>
                </td>
                <td style="font-size:.75rem;color:var(--text-muted);font-weight:500">@c.CompanyType</td>
                <td>
                  <code style="font-family:monospace;font-size:.75rem;background:#F1F5F9;padding:3px 7px;border-radius:5px;color:#475569">@maskedKey</code>
                </td>
                <td><span class="hub-badge @statusCls"><span class="hub-dot"></span>@c.LicenseStatus</span></td>
                <td style="font-size:.75rem;color:@(c.IsExpiringSoon?"var(--warning)":c.IsExpired?"var(--danger)":"var(--text-muted)");font-weight:@(c.IsExpiringSoon||c.IsExpired?"700":"500")">
                  @c.LicenseExpiryDate.ToString("dd MMM yyyy")
                  @if (c.IsExpiringSoon) { <span style="margin-left:4px">⚠</span> }
                </td>
                <td>
                  <span class="hub-badge @(c.IsActive ? "hmac" : "legacy")" title="@(c.IsActive ? "HMAC signing active" : "Legacy auth")">
                    @(c.IsActive ? "🔐 HMAC" : "🔑 Legacy")
                  </span>
                </td>
                <td style="text-align:right">
                  <div style="display:flex;gap:6px;justify-content:flex-end">
                    <a href="@Url.Action("Details","ClientCompany",new{id=c.CompanyId})" class="hub-btn hub-btn-ghost hub-btn-xs">View</a>
                    <a href="@Url.Action("Edit","ClientCompany",new{id=c.CompanyId})" class="hub-btn hub-btn-ghost hub-btn-xs">Edit</a>
                  </div>
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  </div>
</div>

<script>
function filterTable() {
  var q      = document.getElementById('searchInput').value.toLowerCase();
  var status = document.getElementById('statusFilter').value.toLowerCase();
  var rows   = document.querySelectorAll('#clientTable tbody tr');
  var shown  = 0;
  rows.forEach(function(r) {
    var name    = r.dataset.name || '';
    var rstatus = (r.dataset.status || '').toLowerCase();
    var matchQ  = !q      || name.includes(q) || r.textContent.toLowerCase().includes(q);
    var matchS  = status === 'all' || rstatus === status.toLowerCase() ||
                  (status === 'expiringsoon' && rstatus === 'expiringsoon');
    r.style.display = matchQ && matchS ? '' : 'none';
    if (matchQ && matchS) shown++;
  });
  var lbl = document.getElementById('countLabel');
  if (lbl) lbl.textContent = shown + ' client' + (shown !== 1 ? 's' : '');
}
setTimeout(function(){
  document.querySelectorAll('.hub-alert').forEach(function(a){
    a.style.transition='opacity .3s';a.style.opacity='0';
    setTimeout(function(){a.remove()},300);
  });
},5000);
</script>
</body>
</html>
