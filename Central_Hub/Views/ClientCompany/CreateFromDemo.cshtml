@using Central_Hub.Models.ViewModels
@using Central_Hub.Models
@model CreateFromDemoViewModel
@{
    ViewData["Title"] = "Create Client Company — Declarify Central Hub";
    Layout = null;
    var demoRequestId = ViewBag.DemoRequestId ?? Model.DemoRequestId;
    var adminName = User.Identity?.Name ?? "Admin";
    var initials  = string.Concat(adminName.Split(' ').Take(2).Select(w => w.FirstOrDefault())).ToUpper();
    if (string.IsNullOrEmpty(initials)) initials = "CA";
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>@ViewData["Title"]</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link href="~/css/hubcss.css" rel="stylesheet">
    <link href="~/css/createfromdemocss1.css" rel="stylesheet" />
</head>
<body class="page-wrap">

<!-- Navbar -->
<nav class="hub-nav">
  <div class="hub-nav-inner">
    <a href="@Url.Action("Index","Home")" class="hub-brand">
      <img src="~/images/declarify logo.png" alt="Declarify" class="hub-brand-img" />
      <div><div class="hub-brand-text">Declar<span>ify</span></div><div class="hub-brand-sub">Central Hub</div></div>
    </a>
    <span class="hub-env-badge prod" style="margin-left:8px">● Production</span>
    <div class="hub-nav-links" style="margin-left:20px">
      <a href="@Url.Action("Index","Home")" class="hub-nav-link">Dashboard</a>
      <a href="@Url.Action("Index","ClientCompany")" class="hub-nav-link active">Clients</a>
      <a href="@Url.Action("ManageDemoRequest","DemoRequest")" class="hub-nav-link">Demos</a>
    </div>
    <div class="hub-nav-right">
      <div class="hub-nav-user">
        <div class="hub-nav-av">@initials</div>
        <div><div class="hub-nav-name">@adminName</div><div class="hub-nav-role">Central Admin</div></div>
      </div>
    </div>
  </div>
</nav>

<!-- Breadcrumb bar -->
<div style="background:#fff;border-bottom:1px solid var(--border);padding:12px 1rem">
  <div style="max-width:1260px;margin:0 auto;display:flex;align-items:center;gap:7px;font-size:.8125rem;color:var(--text-muted)">
    <a href="@Url.Action("Index","ClientCompany")" style="color:var(--text-muted);text-decoration:none;font-weight:600;transition:color .18s">Clients</a>
    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="width:12px;height:12px"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
    @if (demoRequestId != null) {
      <a href="@Url.Action("DemoRequestDetails","DemoRequest",new{id=demoRequestId})" style="color:var(--text-muted);text-decoration:none;font-weight:600">Demo #@demoRequestId</a>
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="width:12px;height:12px"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
    }
    <span style="color:var(--navy);font-weight:700">Create Company</span>
  </div>
</div>

<!-- Main -->
<div class="cfd-wrap">

  <!-- Sidebar -->
  <div class="cfd-sidebar">
    <div class="side-card">
      <div class="side-body">
        @if (demoRequestId != null) {
          <div class="demo-badge"><span class="demo-badge-dot"></span>Demo #@demoRequestId</div>
        }
        <h2 class="side-title">Convert to<br><span>Client Company</span></h2>
        <p class="side-desc">Review the pre-filled demo details, complete any missing fields, and create the client account with a generated license key.</p>

        <div class="side-steps">
          <div class="side-step active" id="sp1">
            <div class="ss-num">1</div>
            <div><div class="ss-label">Company Information</div><div class="ss-sub">Name, domain, type, province</div></div>
          </div>
          <div class="side-step" id="sp2">
            <div class="ss-num">2</div>
            <div><div class="ss-label">Administrator Details</div><div class="ss-sub">Contact person &amp; credentials</div></div>
          </div>
          <div class="side-step" id="sp3">
            <div class="ss-num">3</div>
            <div><div class="ss-label">Review &amp; Create</div><div class="ss-sub">Confirm and generate license</div></div>
          </div>
        </div>

        <div class="side-box">
          <div class="side-box-title">What happens on create</div>
          <div class="side-box-item"><div class="sbi-dot">🔑</div>Unique DECL-XXXX license key generated</div>
          <div class="side-box-item"><div class="sbi-dot">📧</div>Admin receives login credentials by email</div>
          <div class="side-box-item"><div class="sbi-dot">🚀</div>System accessible immediately via email domain</div>
          <div class="side-box-item"><div class="sbi-dot">✅</div>Demo request marked as Converted</div>
        </div>

        <div class="side-prefill-note">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Fields pre-filled from demo — edit any field as needed.
        </div>
      </div>
    </div>
  </div>

  <!-- Form -->
  <div>

    @if (!ViewData.ModelState.IsValid) {
      <div class="hub-alert error" style="margin-bottom:16px">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Please review the highlighted fields and correct any errors before submitting.
      </div>
    }

    <form asp-action="CreateFromDemo" method="post" id="cfdForm" novalidate>
      @Html.AntiForgeryToken()
      <input type="hidden" asp-for="DemoRequestId" />
      @if (demoRequestId != null) {
        <input type="hidden" name="DemoRequestId" value="@demoRequestId" />
      }

      <!-- Section 1: Company -->
      <div class="form-sec" id="sec1">
        <div class="fs-head">
          <div class="fs-icon navy">🏢</div>
          <div>
            <div class="fs-title">Company Information</div>
            <div class="fs-sub">Step 1 of 2 — Organisation details</div>
          </div>
          @if (Model?.Company?.CompanyName != null) {
            <span class="fs-pre">✓ Pre-filled</span>
          }
        </div>
        <div class="fs-body">
          <div class="pf-notice">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Information imported from demo request — verify each field before creating.
          </div>

          <div class="fg2" style="margin-bottom:16px">
            <div class="cf">
              <label class="cf-lbl" asp-for="Company.CompanyName">Company Name <span class="req">*</span></label>
              <div class="cf-wrap">
                <svg class="cf-ic" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18"/></svg>
                <input asp-for="Company.CompanyName" class="cf-inp ic @(Model?.Company?.CompanyName!=null?"pf":"")" placeholder="e.g. City of Johannesburg" required data-orig="@Model?.Company?.CompanyName" />
              </div>
              <span asp-validation-for="Company.CompanyName" class="cf-err"></span>
            </div>
            <div class="cf">
              <label class="cf-lbl" asp-for="Company.RegistrationNumber">Registration Number <span class="req">*</span></label>
              <div class="cf-wrap">
                <svg class="cf-ic" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
                <input asp-for="Company.RegistrationNumber" class="cf-inp ic @(Model?.Company?.RegistrationNumber!=null?"pf":"")" placeholder="e.g. 2019/123456/07" required data-orig="@Model?.Company?.RegistrationNumber" />
              </div>
              <span asp-validation-for="Company.RegistrationNumber" class="cf-err"></span>
              <span class="cf-hint">Company or entity registration number</span>
            </div>
          </div>

          <div class="fg2" style="margin-bottom:16px">
            <div class="cf">
              <label class="cf-lbl" asp-for="Company.EmailDomain">Email Domain <span class="req">*</span></label>
              <div class="cf-wrap">
                <svg class="cf-ic" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3"/></svg>
                <input asp-for="Company.EmailDomain" id="domainInput" class="cf-inp ic @(Model?.Company?.EmailDomain!=null?"pf":"")" placeholder="e.g. joburg.org.za" required data-orig="@Model?.Company?.EmailDomain" />
              </div>
              <span asp-validation-for="Company.EmailDomain" class="cf-err"></span>
              <span class="cf-hint">Only users with this domain can access the system</span>
            </div>
            <div class="cf">
              <label class="cf-lbl" asp-for="Company.CompanyType">Organisation Type <span class="req">*</span></label>
              <select asp-for="Company.CompanyType" class="cf-sel @(Model?.Company!=null?"pf":"")" required data-orig="@Model?.Company?.CompanyType">
                <option value="">Select type…</option>
                <option value="NationalGovernment">National Government</option>
                <option value="ProvincialGovernment">Provincial Government</option>
                <option value="MunicipalityMetro">Municipality — Metro</option>
                <option value="MunicipalityLocal">Municipality — Local</option>
                <option value="MunicipalityDistrict">Municipality — District</option>
                <option value="StateOwnedEnterprise">State-Owned Enterprise</option>
                <option value="PublicEntity">Public Entity</option>
                <option value="OtherPublicSector">Other Public Sector</option>
              </select>
              <span asp-validation-for="Company.CompanyType" class="cf-err"></span>
            </div>
          </div>

          <div class="fg2">
            <div class="cf">
              <label class="cf-lbl" asp-for="Company.Province">Province</label>
              <select asp-for="Company.Province" class="cf-sel @(Model?.Company?.Province!=null?"pf":"")" data-orig="@Model?.Company?.Province">
                <option value="">Select province…</option>
                <option value="Gauteng">Gauteng</option>
                <option value="Western Cape">Western Cape</option>
                <option value="KwaZulu-Natal">KwaZulu-Natal</option>
                <option value="Eastern Cape">Eastern Cape</option>
                <option value="Free State">Free State</option>
                <option value="Limpopo">Limpopo</option>
                <option value="Mpumalanga">Mpumalanga</option>
                <option value="Northern Cape">Northern Cape</option>
                <option value="North West">North West</option>
              </select>
            </div>
            <div class="cf">
              <label class="cf-lbl" asp-for="Company.EstimatedEmployeeCount">Estimated Employees</label>
              <div class="cf-wrap">
                <svg class="cf-ic" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584"/></svg>
                <input asp-for="Company.EstimatedEmployeeCount" type="number" class="cf-inp ic @(Model?.Company?.EstimatedEmployeeCount!=null?"pf":"")" placeholder="e.g. 500" min="1" data-orig="@Model?.Company?.EstimatedEmployeeCount" />
              </div>
              <span class="cf-hint">Approximate number who will use the system</span>
            </div>
          </div>

          <div class="cf-info">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/></svg>
            <div>
              <div class="cf-info-title">Company Setup</div>
              <div class="cf-info-text">A unique DECL-XXXX license key will be generated automatically. The system will only be accessible from the specified email domain.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Section 2: Administrator -->
      <div class="form-sec" id="sec2">
        <div class="fs-head">
          <div class="fs-icon cyan">👤</div>
          <div>
            <div class="fs-title">Administrator Details</div>
            <div class="fs-sub">Step 2 of 2 — Primary system administrator</div>
          </div>
          @if (Model?.Administrator?.Email != null) {
            <span class="fs-pre">✓ Pre-filled</span>
          }
        </div>
        <div class="fs-body">
          @if (Model?.Administrator != null) {
            <div class="pf-notice">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Contact details imported from demo — edit any field as needed.
            </div>
          }

          <div class="fg2" style="margin-bottom:16px">
            <div class="cf">
              <label class="cf-lbl">First Name <span class="req">*</span></label>
              <div class="cf-wrap">
                <svg class="cf-ic" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/></svg>
                <input type="text" name="Administrator.FirstName" class="cf-inp ic @(Model?.Administrator?.FirstName!=null?"pf":"")" value="@Model?.Administrator?.FirstName" placeholder="e.g. Jane" required data-orig="@Model?.Administrator?.FirstName" />
              </div>
            </div>
            <div class="cf">
              <label class="cf-lbl">Surname <span class="req">*</span></label>
              <div class="cf-wrap">
                <svg class="cf-ic" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/></svg>
                <input type="text" name="Administrator.Surname" class="cf-inp ic @(Model?.Administrator?.Surname!=null?"pf":"")" value="@Model?.Administrator?.Surname" placeholder="e.g. Sithole" required data-orig="@Model?.Administrator?.Surname" />
              </div>
            </div>
          </div>

          <div class="fg2" style="margin-bottom:16px">
            <div class="cf">
              <label class="cf-lbl">Email Address <span class="req">*</span></label>
              <div class="cf-wrap">
                <svg class="cf-ic" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25"/></svg>
                <input type="email" name="Administrator.Email" id="adminEmail" class="cf-inp ic @(Model?.Administrator?.Email!=null?"pf":"")" value="@Model?.Administrator?.Email" placeholder="jane@joburg.org.za" required data-orig="@Model?.Administrator?.Email" />
              </div>
              <span class="cf-hint">Must match the company email domain</span>
            </div>
            <div class="cf">
              <label class="cf-lbl">Employee Number <span class="req">*</span></label>
              <div class="cf-wrap">
                <svg class="cf-ic" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5zm6-10.125a1.875 1.875 0 11-3.75 0 1.875 1.875 0 013.75 0zm1.294 6.336a6.721 6.721 0 01-3.17.789 6.721 6.721 0 01-3.168-.789 3.376 3.376 0 016.338 0z"/></svg>
                <input type="text" name="Administrator.EmployeeNumber" class="cf-inp ic @(Model?.Administrator?.EmployeeNumber!=null?"pf":"")" value="@Model?.Administrator?.EmployeeNumber" placeholder="e.g. EMP12345" required data-orig="@Model?.Administrator?.EmployeeNumber" />
              </div>
              <span class="cf-hint">Staff ID number within the organisation</span>
            </div>
          </div>

          <div class="fg2" style="margin-bottom:16px">
            <div class="cf">
              <label class="cf-lbl">Phone Number <span class="req">*</span></label>
              <div class="cf-wrap">
                <svg class="cf-ic" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
                <input type="tel" name="Administrator.PhoneNumber" class="cf-inp ic @(Model?.Administrator?.PhoneNumber!=null?"pf":"")" value="@Model?.Administrator?.PhoneNumber" placeholder="+27 11 000 0000" required data-orig="@Model?.Administrator?.PhoneNumber" />
              </div>
            </div>
            <div class="cf">
              <label class="cf-lbl">Job Title</label>
              <div class="cf-wrap">
                <svg class="cf-ic" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175"/></svg>
                <input type="text" name="Administrator.JobTitle" class="cf-inp ic @(Model?.Administrator?.JobTitle!=null?"pf":"")" value="@Model?.Administrator?.JobTitle" placeholder="e.g. Compliance Manager" data-orig="@Model?.Administrator?.JobTitle" />
              </div>
            </div>
          </div>

          <div class="fg1">
            <div class="cf">
              <label class="cf-lbl">Department</label>
              <div class="cf-wrap">
                <svg class="cf-ic" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21"/></svg>
                <input type="text" name="Administrator.Department" class="cf-inp ic @(Model?.Administrator?.Department!=null?"pf":"")" value="@Model?.Administrator?.Department" placeholder="e.g. Corporate Governance" data-orig="@Model?.Administrator?.Department" />
              </div>
            </div>
          </div>

          <div class="cf-info cyan">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
            <div>
              <div class="cf-info-title">Administrator Privileges</div>
              <div class="cf-info-text">Full access to manage users, templates, compliance tracking, and settings. Login credentials sent to their email on account creation.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Submit -->
      <div class="sub-panel" id="sec3">
        <div class="sub-title">Review &amp; Create Company</div>
        <div class="sub-desc">Once submitted a unique license key is generated, the demo request is marked as Converted, and the administrator receives login credentials by email. This action cannot be undone.</div>
        <button type="submit" class="sub-btn" id="subBtn">
          <span>Create Company &amp; Generate License</span>
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div class="sub-spinner"></div>
        </button>
        <a href="@Url.Action("Index","ClientCompany")" class="sub-cancel">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          Cancel &amp; go back
        </a>
        <div class="sub-note">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
          AES-256 encrypted · Audit trail logged
        </div>
      </div>
    </form>
  </div>
</div>

<script>
// Sidebar step progress
function updateSteps(){
  var s2=document.getElementById('sec2'), s3=document.getElementById('sec3');
  var sp1=document.getElementById('sp1'), sp2=document.getElementById('sp2'), sp3=document.getElementById('sp3');
  var vh=window.innerHeight*.55;
  [sp1,sp2,sp3].forEach(function(s){s.classList.remove('active','done')});
  if(s3&&s3.getBoundingClientRect().top<vh){sp1.classList.add('done');sp2.classList.add('done');sp3.classList.add('active')}
  else if(s2&&s2.getBoundingClientRect().top<vh){sp1.classList.add('done');sp2.classList.add('active')}
  else{sp1.classList.add('active')}
}
window.addEventListener('scroll',updateSteps,{passive:true});
updateSteps();

// Modified field highlight
document.querySelectorAll('[data-orig]').forEach(function(el){
  var orig=el.dataset.orig||'';
  el.addEventListener('input',function(){
    el.classList.toggle('mod', el.value!==orig && orig!=='');
    el.classList.toggle('pf',  el.value===orig && orig!=='');
  });
});

// Email-domain validation
var domainInput=document.getElementById('domainInput');
var adminEmail=document.getElementById('adminEmail');
if(domainInput&&adminEmail){
  function checkDomain(){
    var d=domainInput.value.toLowerCase().trim();
    var e=adminEmail.value.toLowerCase().trim();
    if(d&&e&&e.includes('@@')){
      adminEmail.setCustomValidity(e.endsWith('@@'+d)?'':'Email must end with @@'+d);
    } else { adminEmail.setCustomValidity(''); }
  }
  domainInput.addEventListener('input',checkDomain);
  adminEmail.addEventListener('blur',checkDomain);
  adminEmail.addEventListener('input',function(){adminEmail.setCustomValidity('');});
}

// Submit confirm + loading
document.getElementById('cfdForm').addEventListener('submit',function(e){
  var n=(document.querySelector('[name="Company.CompanyName"]')||{value:'this company'}).value;
  if(!confirm('Create client "'+n+'"?\n\n✓ Unique license key will be generated\n✓ Admin receives credentials by email\n✓ Demo request marked Converted\n\nThis cannot be undone.')){
    e.preventDefault(); return;
  }
  var btn=document.getElementById('subBtn');
  btn.classList.add('loading'); btn.disabled=true;
});
</script>
</body>
</html>
