        <div class="widget-stats">
          <div class="wstat"><div class="wstat-val"><span id="c1">0</span>%</div><div class="wstat-lbl">Time Saved</div></div>
          <div class="wstat"><div class="wstat-val"><span id="c2">0</span>s</div><div class="wstat-lbl">Avg Submit</div></div>
          <div class="wstat"><div class="wstat-val"><span id="c3">0</span>%</div><div class="wstat-lbl">Audit Ready</div></div>
        </div>
      </div>
      <div class="float-card fc-top">
        <div class="fc-icon">✅</div>
        <div><div class="fc-text">Bulk Request Sent</div><div class="fc-sub">247 employees notified</div></div>
      </div>
      <div class="float-card fc-bottom">
        <div class="fc-icon">🔐</div>
        <div><div class="fc-text">AES-256 Encrypted</div><div class="fc-sub">All data secured</div></div>
      </div>
    </div>
  </div>
</section>

