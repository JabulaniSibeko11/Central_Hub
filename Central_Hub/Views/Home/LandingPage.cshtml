        <span class="hero-trust-label">Built for</span>
        <div class="hero-trust-badges">
          <span class="trust-badge">🏛️ Municipalities</span>
          <span class="trust-badge">🏢 Government Depts</span>
          <span class="trust-badge">🔒 POPIA Compliant</span>
        </div>
      </div>
    </div>

    <div class="hero-widget">
      <div class="compliance-ring-card">
        <div class="ring-wrap">
          <svg class="compliance-ring-svg" viewBox="0 0 180 180" id="complianceRing">
            <defs>
              <linearGradient id="ringGrad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#00C2CB"/>
                <stop offset="100%" stop-color="#00E5FF"/>
