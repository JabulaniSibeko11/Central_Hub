<!-- ── HERO ─────────────────────────────────────────────────── -->
<section class="hero">
  <div class="hero-grid"></div>
  <div class="rh rh1"></div><div class="rh rh2"></div>
  <div class="rh rh3"></div><div class="rh rh4"></div><div class="rh rh5"></div>
