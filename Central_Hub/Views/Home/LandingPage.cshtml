  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-eyebrow"><span></span> Trusted by South African Public Sector</div>
      <h1 class="hero-title">
        Public Sector<br>Integrity.<br>
        <span class="accent underline-accent">Clarified.</span>
      </h1>
      <p class="hero-desc">
        Declarify is the secure, automated compliance platform that makes
        Declaration of Interest management effortless for government agencies,
        municipalities, and public entities across South Africa.
      </p>
      <div class="hero-actions">
      @*   <a href="@Url.Action("RequestDemo","DemoRequest")" class="btn btn-primary">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5"/></svg>
