@using Central_Hub.Models.ViewModels
@using Central_Hub.Models
@model DashboardViewModel
@{
    Layout = null;
    ViewData["Title"] = "Dashboard — Declarify Central Hub";
    var adminName = User.Identity?.Name ?? "Admin";
    var initials = string.Concat(adminName.Split(' ').Take(2).Select(w => w.FirstOrDefault())).ToUpper();
    if (string.IsNullOrEmpty(initials)) initials = "CA";
    var creditUsePct = Model.TotalCreditsPurchased > 0
        ? (int)Math.Round((double)Model.TotalCreditsUsed / Model.TotalCreditsPurchased * 100) : 0;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="~/css/hubcss.css" rel="stylesheet">
</head>
<body>

    <!-- ── Navbar ──────────────────────────────────────────────── -->
    <nav class="hub-nav">
        <div class="hub-nav-inner">
            <a href="@Url.Action("Index", "Home")" class="hub-brand">
                <img src="~/images/declarify logo.png" alt="Declarify" class="hub-brand-img" />
                <div>
                    <div class="hub-brand-text">Declar<span>ify</span></div>
                    <div class="hub-brand-sub">Central Hub</div>
                </div>
            </a>
            <span class="hub-env-badge prod">● Production</span>

            <div class="hub-nav-links" style="margin-left:24px">
                <a href="@Url.Action("Index", "Home")" class="hub-nav-link active">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75" /></svg>
                    Dashboard
                </a>
                <a href="@Url.Action("Index", "ClientCompany")" class="hub-nav-link">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" /></svg>
                    Clients
                </a>
                <a href="@Url.Action("ManageDemoRequest", "DemoRequest")" class="hub-nav-link">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5" /></svg>
                    Demos
                    @if (Model.PendingDemoRequests > 0)
                    {
                        <span style="background:var(--danger);color:#fff;font-size:.5rem;font-weight:800;padding:1px 5px;border-radius:99px;min-width:16px;text-align:center">@Model.PendingDemoRequests</span>
                    }
                </a>
                <a href="@Url.Action("RequestedCredits", "Home")" class="hub-nav-link">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" /></svg>
                    Credits
                </a>
            </div>

            <div class="hub-nav-right">
                <div class="hub-sec-bar" style="padding:6px 12px;font-size:.6875rem">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
                    HMAC + AES-256 Active
                </div>
                <div class="hub-nav-user">
                    <div class="hub-nav-av">@initials</div>
                    <div>
                        <div class="hub-nav-name">@adminName</div>
                        <div class="hub-nav-role">Central Admin</div>
                    </div>
                </div>
                <form method="post" action="@Url.Action("Logout","Home")" style="margin:0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="hub-btn hub-btn-ghost hub-btn-sm">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" /></svg>
                        Sign Out
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <!-- ── Hero ────────────────────────────────────────────────── -->
    <div class="hub-hero">
        <div class="hub-hero-inner">
            <div>
                <div class="hub-hero-eyebrow">🏛️ Operations Centre</div>
                <h1 class="hub-hero-title">Declarify <span>Central Hub</span></h1>
                <p class="hub-hero-desc">Real-time oversight of all client licenses, credits, and compliance deployments.</p>
                <div class="hub-hero-actions">
                    <a href="@Url.Action("Create", "ClientCompany")" class="hub-btn hub-btn-cyan">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="width:14px;height:14px"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                        New Client
                    </a>
                    <a href="@Url.Action("RequestedCredits", "Home")" class="hub-btn hub-btn-cyan" style="color:#fff;border-color:rgba(255,255,255,.25)">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" /></svg>
                        Credit Requests
                        @if (Model.PendingDemoRequests > 0)
                        {
                            <span style="background:var(--danger);color:#fff;border-radius:99px;font-size:.5rem;font-weight:800;padding:1px 6px">!</span>
                        }
                    </a>
                </div>
            </div>
            <div class="hub-hero-stat">
                <div class="hub-hero-stat-val">@Model.ActiveClients<span>/</span>@Model.TotalClients</div>
                <div class="hub-hero-stat-lbl">Active Clients</div>
            </div>
        </div>
    </div>

    <!-- ── KPI Strip ────────────────────────────────────────────── -->
    <div class="hub-kpi-strip">
        <div class="hub-kpi-inner">
            <div class="hub-kpi navy hub-anim">
                <div class="hub-kpi-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" /></svg></div>
                <div><div class="hub-kpi-val">@Model.TotalClients</div><div class="hub-kpi-lbl">Total Clients</div></div>
                <div class="hub-kpi-accent"></div>
            </div>
            <div class="hub-kpi green hub-anim">
                <div class="hub-kpi-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></div>
                <div><div class="hub-kpi-val">@Model.ActiveClients</div><div class="hub-kpi-lbl">Active Licenses</div></div>
                <div class="hub-kpi-accent"></div>
            </div>
            <div class="hub-kpi cyan hub-anim">
                <div class="hub-kpi-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" /></svg></div>
                <div><div class="hub-kpi-val">@Model.TotalCreditsInCirculation.ToString("N0")</div><div class="hub-kpi-lbl">Credits Active</div></div>
                <div class="hub-kpi-accent"></div>
            </div>
            <div class="hub-kpi @(Model.PendingDemoRequests > 0 ? "amber" : "green") hub-anim">
                <div class="hub-kpi-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5" /></svg></div>
                <div><div class="hub-kpi-val">@Model.PendingDemoRequests</div><div class="hub-kpi-lbl">Pending Demos</div></div>
                <div class="hub-kpi-accent"></div>
            </div>
            <div class="hub-kpi @(Model.ExpiredClients > 0 ? "red" : "green") hub-anim">
                <div class="hub-kpi-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z" /></svg></div>
                <div><div class="hub-kpi-val">@Model.ExpiredClients</div><div class="hub-kpi-lbl">Expired Licenses</div></div>
                <div class="hub-kpi-accent"></div>
            </div>
        </div>
    </div>

    <!-- ── Main content ─────────────────────────────────────────── -->
    <div class="hub-main">

        @if (TempData["Success"] != null)
        {
            <div class="hub-alert success">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                @TempData["Success"]
            </div>
        }

        <!-- Row 1: Alerts + Credit Overview -->
        <div class="hub-g2" style="margin-bottom:20px">

            <!-- Expiring licenses -->
            <div class="hub-card hub-anim">
                <div class="hub-card-head">
                    <div class="hub-card-icon amber">⚠️</div>
                    <div><div class="hub-card-title">Expiring Licenses</div><div class="hub-card-sub">Expire within 30 days</div></div>
                    <div class="hub-card-action"><a href="@Url.Action("Index", "ClientCompany")" class="hub-btn hub-btn-ghost hub-btn-xs">View all</a></div>
                </div>
                @if (!Model.ExpiringLicenses.Any())
                {
                    <div class="hub-empty" style="padding:30px">
                        <div style="font-size:26px">✅</div>
                        <div class="hub-empty-title" style="font-size:.875rem">All licenses healthy</div>
                    </div>
                }
                else
                {
                    <div class="hub-table-wrap">
                        <table class="hub-table">
                            <thead><tr><th>Company</th><th>Expires</th><th>Days</th></tr></thead>
                            <tbody>
                                @foreach (var c in Model.ExpiringLicenses)
                                {
                                    var days = c.DaysUntilExpiry;
                                    <tr>
                                        <td><div class="hub-co-cell"><div class="hub-co-av">@string.Concat((c.CompanyName ?? "??").Split(' ').Take(2).Select(w => w.FirstOrDefault())).ToUpper()</div><div><div class="hub-co-name">@c.CompanyName</div></div></div></td>
                                        <td style="color:var(--text-muted);font-size:.75rem">@c.LicenseExpiryDate.ToString("dd MMM yyyy")</td>
                                        <td><span class="hub-badge @(days <= 7 ? "expired" : "expiring")"><span class="hub-dot"></span>@days days</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <!-- Credit overview -->
            <div class="hub-card hub-anim">
                <div class="hub-card-head">
                    <div class="hub-card-icon cyan">💳</div>
                    <div><div class="hub-card-title">Credit Overview</div><div class="hub-card-sub">Across all clients</div></div>
                </div>
                <div class="hub-card-body">
                    <div class="hub-g2" style="gap:12px;margin-bottom:18px">
                        @foreach (var (label, val, colour) in new[]{
                                                ("Purchased", Model.TotalCreditsPurchased.ToString("N0"), "#081B38"),
                                                ("Used",      Model.TotalCreditsUsed.ToString("N0"),      "#EF4444"),
                                                ("Active",    Model.TotalCreditsInCirculation.ToString("N0"), "#00C2CB"),
                                                ("Use Rate",  creditUsePct + "%",                          creditUsePct>80?"#EF4444":"#10B981")
                                                })
                        {
                            <div style="background:#F8FAFC;border:1px solid #E2E8F0;border-radius:10px;padding:12px 14px">
                                <div style="font-size:.5625rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:#94A3B8;margin-bottom:4px">@label</div>
                                <div style="font-family:'Montserrat',sans-serif;font-size:1.25rem;font-weight:800;letter-spacing:-.04em;color:@colour">@val</div>
                            </div>
                        }
                    </div>
                    <div style="margin-bottom:6px;display:flex;justify-content:space-between;font-size:.75rem;font-weight:600;color:var(--text-muted)">
                        <span>Credit Utilisation</span><span>@creditUsePct%</span>
                    </div>
                    <div class="hub-credit-bar">
                        <div class="hub-credit-fill" style="width:@creditUsePct%;background:@(creditUsePct > 80 ? "var(--danger)" : "linear-gradient(90deg,var(--cyan),var(--cyan-deep))")"></div>
                    </div>

                    @if (Model.LowCreditClients.Any())
                    {
                        <div style="margin-top:14px">
                            <div style="font-size:.6875rem;font-weight:700;color:var(--warning);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">⚠ Low Credit Clients</div>
                            @foreach (var c in Model.LowCreditClients.Take(3))
                            {
                                <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 10px;background:#FEF3C7;border-radius:8px;margin-bottom:4px;font-size:.8125rem">
                                    <span style="font-weight:600;color:#92400E">@c.CompanyName</span>
                                    <a href="@Url.Action("Details", "ClientCompany", new { id = c.CompanyId })" class="hub-btn hub-btn-ghost hub-btn-xs">Manage</a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Row 2: Recent clients + Recent transactions -->
        <div class="hub-g2" style="margin-bottom:20px">
            <!-- Recent clients -->
            <div class="hub-card hub-anim">
                <div class="hub-card-head">
                    <div class="hub-card-icon navy">🏢</div>
                    <div><div class="hub-card-title">Recent Clients</div><div class="hub-card-sub">Latest onboarded</div></div>
                    <div class="hub-card-action"><a href="@Url.Action("Index", "ClientCompany")" class="hub-btn hub-btn-ghost hub-btn-xs">All clients</a></div>
                </div>
                @if (!Model.RecentClients.Any())
                {
                    <div class="hub-empty" style="padding:30px"><div class="hub-empty-icon">🏢</div><div class="hub-empty-desc">No clients yet</div></div>
                }
                else
                {
                    <div class="hub-table-wrap">
                        <table class="hub-table">
                            <thead><tr><th>Company</th><th>Status</th><th>Expires</th><th></th></tr></thead>
                            <tbody>
                                @foreach (var c in Model.RecentClients)
                                {
                                    var statusCls = c.LicenseStatus == LicenseStatus.Active ? "active"
                                    : c.LicenseStatus == LicenseStatus.Trial ? "trial"
                                    : c.LicenseStatus == LicenseStatus.Expired ? "expired" : "expiring";
                                    <tr>
                                        <td><div class="hub-co-cell"><div class="hub-co-av">@string.Concat((c.CompanyName ?? "??").Split(' ').Take(2).Select(w => w.FirstOrDefault())).ToUpper()</div><div><div class="hub-co-name">@c.CompanyName</div><div class="hub-co-type">@c.CompanyType</div></div></div></td>
                                        <td><span class="hub-badge @statusCls"><span class="hub-dot"></span>@c.LicenseStatus</span></td>
                                        <td style="font-size:.75rem;color:var(--text-muted)">@c.LicenseExpiryDate.ToString("dd MMM yy")</td>
                                        <td><a href="@Url.Action("Details", "ClientCompany", new { id = c.CompanyId })" class="hub-btn hub-btn-ghost hub-btn-xs">View</a></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <!-- Recent credit transactions -->
            <div class="hub-card hub-anim">
                <div class="hub-card-head">
                    <div class="hub-card-icon green">💳</div>
                    <div><div class="hub-card-title">Recent Transactions</div><div class="hub-card-sub">Latest credit activity</div></div>
                </div>
                @if (!Model.RecentCreditTransactions.Any())
                {
                    <div class="hub-empty" style="padding:30px"><div class="hub-empty-icon">📋</div><div class="hub-empty-desc">No transactions yet</div></div>
                }
                else
                {
                    <div class="hub-table-wrap">
                        <table class="hub-table">
                            <thead><tr><th>Company</th><th>Type</th><th>Credits</th><th>Date</th></tr></thead>
                            <tbody>
                                @foreach (var t in Model.RecentCreditTransactions)
                                {
                                    var isSpend = t.TransactionType == CreditTransactionType.Spend;
                                    <tr>
                                        <td style="font-weight:600;font-size:.8125rem">@(t.Company?.CompanyName ?? "—")</td>
                                        <td>
                                            <span class="hub-badge @(isSpend ? "rejected" : "approved")">
                                                <span class="hub-dot"></span>@t.TransactionType
                                            </span>
                                        </td>
                                        <td style="font-family:'Montserrat',sans-serif;font-weight:800;color:@(isSpend ? "var(--danger)" : "var(--success)")">
                                            @(isSpend ? "-" : "+")@t.CreditsAmount
                                        </td>
                                        <td style="font-size:.75rem;color:var(--text-muted)">@t.TransactionDate.ToString("dd MMM HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Row 3: Demo funnel + Security status -->
        <div class="hub-g2">
            <!-- Demo funnel -->
            <div class="hub-card hub-anim">
                <div class="hub-card-head">
                    <div class="hub-card-icon purple">📅</div>
                    <div><div class="hub-card-title">Demo Pipeline</div><div class="hub-card-sub">Conversion rate: @Model.ConversionRate.ToString("F1")%</div></div>
                    <div class="hub-card-action"><a href="@Url.Action("ManageDemoRequest", "DemoRequest")" class="hub-btn hub-btn-ghost hub-btn-xs">Manage</a></div>
                </div>
                <div class="hub-card-body">
                    <div class="hub-g4" style="gap:10px">
                        @foreach (var (label, val, emoji, bg) in new[]{
                                                ("Pending",   Model.PendingDemoRequests, "⏳", "rgba(245,158,11,.08)"),
                                                ("Scheduled", Model.ScheduledDemos,      "📅", "rgba(59,130,246,.08)"),
                                                ("Completed", Model.CompletedDemos,      "✅", "rgba(16,185,129,.08)"),
                                                ("Converted", Model.ConvertedDemos,      "🚀", "rgba(0,194,203,.08)")
                                                })
                        {
                            <div style="background:@bg;border-radius:10px;padding:14px 12px;text-align:center">
                                <div style="font-size:20px;margin-bottom:4px">@emoji</div>
                                <div style="font-family:'Montserrat',sans-serif;font-size:1.375rem;font-weight:800;color:#081B38">@val</div>
                                <div style="font-size:.5625rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#64748B;margin-top:2px">@label</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Security status -->
            <div class="hub-card hub-anim">
                <div class="hub-card-head">
                    <div class="hub-card-icon green">🔐</div>
                    <div><div class="hub-card-title">Security Status</div><div class="hub-card-sub">Active protections</div></div>
                </div>
                <div class="hub-card-body">
                    @foreach (var (label, desc, active) in new[]{
                                        ("AES-256 Encryption",    "Sensitive fields encrypted at rest",               true),
                                        ("HMAC-SHA256 Signing",   "Per-request API signature verification",           true),
                                        ("Replay Attack Guard",   "Nonce cache + timestamp window (±5 min)",          true),
                                        ("Rate Limiting",         "120 requests/min per company",                     true),
                                        ("Security Headers",     "X-Frame, X-XSS, CSP, Referrer-Policy active",      true),
                                        ("Audit Trail",           "All API calls logged to ApiAuditLogs",             true)
                                        })
                    {
                        <div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid #F1F5F9">
                            <div style="width:28px;height:28px;border-radius:7px;background:rgba(16,185,129,.1);color:#065F46;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0">✓</div>
                            <div style="flex:1">
                                <div style="font-size:.8125rem;font-weight:700;color:#1E293B">@label</div>
                                <div style="font-size:.6875rem;color:#94A3B8;font-weight:500">@desc</div>
                            </div>
                            <span class="hub-badge active"><span class="hub-dot"></span>Active</span>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>

    <script>
        // Auto-dismiss alerts
        setTimeout(function(){
          document.querySelectorAll('.hub-alert').forEach(function(a){
            a.style.transition='opacity .3s';a.style.opacity='0';
            setTimeout(function(){a.remove()},300);
          });
        },5000);
    </script>
</body>
</html>
